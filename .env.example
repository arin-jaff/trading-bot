# Kalshi API - RSA key authentication
# Get your API key and generate RSA key at: https://kalshi.com/account/api
KALSHI_API_KEY=your_api_key_id_here
KALSHI_PRIVATE_KEY_PATH=path/to/your/kalshi_private_key.pem
KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2

# Colab fine-tuned model API (set when running Colab API server with ngrok)
COLAB_PREDICTION_URL=

# Database
DATABASE_URL=sqlite:///data/trading_bot.db

# Scraping
YOUTUBE_API_KEY=your_youtube_api_key_here

# App settings
LOG_LEVEL=INFO
REFRESH_INTERVAL_SECONDS=60
