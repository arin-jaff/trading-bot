# Kalshi API credentials
KALSHI_API_KEY=your_api_key_here
KALSHI_EMAIL=your_email_here
KALSHI_PASSWORD=your_password_here
KALSHI_BASE_URL=https://trading-api.kalshi.com/trade-api/v2

# OpenAI API (optional - not needed if using Colab model)
OPENAI_API_KEY=

# Anthropic API (optional - not needed if using Colab model)
ANTHROPIC_API_KEY=

# Colab fine-tuned model API (set when running Colab API server with ngrok)
COLAB_PREDICTION_URL=

# Database
DATABASE_URL=sqlite:///data/trading_bot.db

# Scraping
YOUTUBE_API_KEY=your_youtube_api_key_here

# App settings
LOG_LEVEL=INFO
REFRESH_INTERVAL_SECONDS=60
